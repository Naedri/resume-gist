{
  "name": "resume-gist",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "repository": {
    "url": "https://github.com/Naedri/resume-gist.git",
    "type": "git"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "npm run build:server && npm run build:client",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/server.ts --outDir dist",
    "lint": "eslint .",
    "preview": "npm run build && npm run start",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "generate:resume-types": "json2ts node_modules/@jsonresume/schema/schema.json --output src/types/json-resume.d.ts",
    "prepare": "npm run generate:resume-types"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "i18next": "^25.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.3",
    "sirv": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@jsonresume/core": "^0.1.0",
    "@jsonresume/schema": "^1.2.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
